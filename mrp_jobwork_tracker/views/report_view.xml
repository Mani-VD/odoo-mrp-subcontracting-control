<odoo>
    <record id="view_subcontractor_stock_report_list" model="ir.ui.view">
        <field name="name">subcontractor.stock.report.list</field>
        <field name="model">subcontractor.stock.report</field>
        <field name="arch" type="xml">
            <list string="Subcontractor Stock" create="false" edit="false">
                <field name="location_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="total_value" sum="Total Value at Vendor"/>
            </list>
        </field>
    </record>

    <record id="action_subcontractor_stock_report" model="ir.actions.act_window">
        <field name="name">Inventory at Vendors</field>
        <field name="res_model">subcontractor.stock.report</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_subcontractor_report" 
              name="Vendor Stock Analysis" 
              parent="mrp.menu_mrp_reporting" 
              action="action_subcontractor_stock_report" 
              sequence="100"/>
</odoo>